AWS_PROFILE=<YOUR_AWS_PROFILE>
AWS_REGION=us-east-2
TF_VAR_aws_profile=<YOUR_AWS_PROFILE>
TF_VAR_aws_region=us-east-2
TF_VAR_allowed_aws_account_id=<YOUR_12_DIGIT_AWS_ACCOUNT_ID>
TF_VAR_project_name=zt-infra-v2
TF_VAR_tailscale_secret_name=<YOUR_PROJECT>/tailscale-auth-key
TAILSCALE_SECRET_NAME=<YOUR_PROJECT>/tailscale-auth-key

# Optional DAAL blockchain attestation sidecar.
DAAL_ENABLED=false
DAAL_PROVIDER_MODE=cdp
DAAL_NETWORK=base-sepolia
DAAL_CONTRACT_ADDRESS=0xREPLACE_ME
DAAL_BATCH_SIZE=10
DAAL_METADATA_BASE_URI=

# Alchemy provider RPC. Required for receipt verification and ethers fallback mode.
ALCHEMY_API_KEY=REPLACE_ME
DAAL_RPC_URL=

# Coinbase Developer Platform Server Wallet signer. Required for cdp mode.
CDP_API_KEY_ID=REPLACE_ME
CDP_API_KEY_SECRET=REPLACE_ME
CDP_WALLET_SECRET=REPLACE_ME
CDP_EVM_ACCOUNT_ADDRESS=0xREPLACE_ME

# Optional thirdweb Engine provider. Use only if this wallet is registered in Engine.
# Store real values in AWS Secrets Manager or your deployment secret store, not Git.
THIRDWEB_ENGINE_URL=https://engine.thirdweb.com
THIRDWEB_ENGINE_ACCESS_TOKEN=REPLACE_ME
THIRDWEB_BACKEND_WALLET_ADDRESS=0xREPLACE_ME
THIRDWEB_ENGINE_CHAIN=84532
# Optional: set to sponsored only where thirdweb Engine/paymaster supports it.
THIRDWEB_ENGINE_TRANSACTION_MODE=

# thirdweb deployment helper. Do not commit real secret values.
THIRDWEB_SECRET_KEY=REPLACE_ME
