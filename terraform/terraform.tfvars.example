aws_profile           = "<YOUR_AWS_PROFILE>"
aws_region            = "us-east-2"
allowed_aws_account_id = "<YOUR_12_DIGIT_AWS_ACCOUNT_ID>"
project_name          = "zt-infra"
tailscale_secret_name = "<YOUR_PROJECT>/tailscale-auth-key"
instance_type         = "t3.micro"
allowed_operator_cidr = "0.0.0.0/32" # intentionally unusable; no public ingress is created
